{
  "name": "@mercuryworkshop/scramjet-utils",
  "version": "0.0.3",
  "description": "Utilities for Scramjet proxy integrations",
  "type": "module",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/MercuryWorkshop/scramjet.git",
    "directory": "packages/utils"
  },
  "types": "./dist/types/typesEntry.d.ts",
  "exports": {
    ".": {
      "types": "./dist/types/typesEntry.d.ts",
      "import": "./dist/scramjet-utils.mjs",
      "default": "./dist/scramjet-utils.js"
    }
  },
  "files": [
    "dist"
  ],
  "peerDependencies": {
    "@mercuryworkshop/scramjet": "*",
    "@mercuryworkshop/scramjet-controller": "*"
  },
  "devDependencies": {
    "@types/serviceworker": "^0.0.197",
    "@mercuryworkshop/scramjet": "2.0.67-alpha.1",
    "@mercuryworkshop/scramjet-controller": "0.0.13"
  },
  "scripts": {
    "build": "cd ../.. && rspack build --mode production",
    "pub": "pnpm publish --no-git-checks --access public"
  }
}